<file path="assets/css/community.css">
/* Root variables matching My Coach theme */
:root {
  --primary: #407C87;
  --accent: #A5DBDD;
  --surface: #EEF1F6;
  --border: #D3E1E2;
  --dark: #1a3a3f;
  --white: #ffffff;
  --ease: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
}

/* Reset and base styles */
* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: 'Inter', 'Segoe UI', sans-serif;
  background: linear-gradient(135deg, #f0f8fb 0%, #eef1f6 100%);
  color: var(--dark);
  line-height: 1.6;
  min-height: 100vh;
  overflow-x: hidden;
}

/* ========== HEADER STYLING ========== */
.header {
  position: sticky;
  top: 0;
  z-index: 1000;
  background: rgba(255, 255, 255, 0.85);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(64, 124, 135, 0.1);
  padding: 1rem;
}

.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  max-width: 1400px;
  margin: 0 auto;
  padding: 0 2rem;
}

.logo a {
  font-size: 1.6rem;
  font-weight: 800;
  color: var(--primary);
  text-decoration: none;
  letter-spacing: -0.5px;
}

.links {
  display: flex;
  list-style: none;
  gap: 2rem;
  margin: 0;
}

.links a {
  text-decoration: none;
  color: var(--dark);
  font-weight: 500;
  font-size: 0.95rem;
  position: relative;
  transition: var(--ease);
}

.links a::after {
  content: '';
  position: absolute;
  bottom: -4px;
  left: 0;
  width: 0;
  height: 2px;
  background: var(--primary);
  transition: width 0.3s ease;
}

.links a:hover::after,
.links a.active::after {
  width: 100%;
}

.nav-buttons {
  display: flex;
  align-items: center;
  gap: 1rem;
}

.user-menu {
  position: relative;
}

.user-avatar img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  cursor: pointer;
  border: 2px solid var(--accent);
  transition: var(--ease);
}

.user-avatar img:hover {
  transform: scale(1.1);
}

.user-profile-menu {
  position: absolute;
  top: 110%;
  right: 0;
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  box-shadow: 0 8px 30px rgba(64, 124, 135, 0.15);
  min-width: 160px;
  display: none;
  z-index: 1100;
  overflow: hidden;
}

.user-profile-menu.active {
  display: block;
}

.profile-menu-item {
  width: 100%;
  padding: 0.8rem 1rem;
  border: none;
  background: transparent;
  text-align: left;
  cursor: pointer;
  color: var(--dark);
  font-size: 0.92rem;
  font-weight: 500;
  transition: var(--ease);
}

.profile-menu-item:hover {
  background: var(--surface);
  color: var(--primary);
}

/* ========== MAIN CONTAINER LAYOUT ========== */
.main-container {
  display: grid;
  grid-template-columns: 200px 1fr 300px;
  gap: 2rem;
  max-width: 1400px;
  margin: 2rem auto;
  padding: 0 2rem;
}

/* ========== LEFT SIDEBAR ========== */
.sidebar-left {
  position: sticky;
  top: 100px;
  height: fit-content;
}

.sidebar-menu {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.menu-item {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  padding: 1rem;
  text-decoration: none;
  color: var(--dark);
  font-weight: 500;
  border-left: 3px solid transparent;
  transition: var(--ease);
  cursor: pointer;
}

.menu-item:hover {
  background: var(--surface);
  border-left-color: var(--accent);
}

.menu-item.active {
  background: var(--surface);
  color: var(--primary);
  border-left-color: var(--primary);
}

.menu-icon {
  font-size: 1.2rem;
}

.menu-text {
  font-size: 0.95rem;
}

/* ========== MAIN CONTENT ========== */
.main-content {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.section {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 2rem;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 2rem;
  flex-wrap: wrap;
  gap: 1rem;
}

.section-header h2 {
  font-size: 1.5rem;
  color: var(--dark);
}

/* ========== FILTER BUTTONS ========== */
.filter-buttons {
  display: flex;
  gap: 0.5rem;
}

.filter-btn {
  padding: 0.6rem 1.2rem;
  border: 1px solid var(--border);
  background: var(--white);
  color: var(--dark);
  border-radius: 8px;
  cursor: pointer;
  font-weight: 500;
  transition: var(--ease);
}

.filter-btn:hover {
  background: var(--surface);
  border-color: var(--accent);
}

.filter-btn.active {
  background: var(--primary);
  color: var(--white);
  border-color: var(--primary);
}

/* ========== LEADERBOARD ========== */
.leaderboard-container {
  display: flex;
  flex-direction: column;
  gap: 2rem;
}

.leaderboard-top-3 {
  display: grid;
  grid-template-columns: 1fr 1.2fr 1fr;
  gap: 1.5rem;
  margin-bottom: 1rem;
}

.rank-card {
  background: linear-gradient(135deg, var(--surface) 0%, #f5fbfc 100%);
  border: 2px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  position: relative;
  transition: var(--ease);
}

.rank-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 24px rgba(64, 124, 135, 0.15);
}

.rank-card.rank-1 {
  border-color: #FFD700;
  background: linear-gradient(135deg, #FFFDE7 0%, #FFF9C4 100%);
  transform: scale(1.05);
}

.rank-card.rank-2 {
  border-color: #C0C0C0;
  background: linear-gradient(135deg, #F5F5F5 0%, #E8E8E8 100%);
}

.rank-card.rank-3 {
  border-color: #CD7F32;
  background: linear-gradient(135deg, #FFE8D6 0%, #FFD7B5 100%);
}

.rank-card.is-you {
  box-shadow: 0 0 0 2px var(--primary);
}

.rank-position {
  font-size: 0.8rem;
  color: var(--primary);
  font-weight: 700;
  margin-bottom: 0.5rem;
  text-transform: uppercase;
}

.rank-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  border: 3px solid var(--accent);
  margin: 0.5rem auto 1rem;
  object-fit: cover;
}

.rank-card h3 {
  font-size: 1.1rem;
  margin-bottom: 0.5rem;
  color: var(--dark);
}

.user-initials-avatar {
  width: 80px;
  height: 80px;
  border-radius: 50%;
  background: var(--primary);
  color: white;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 2rem;
  font-weight: 700;
  margin: 0.5rem auto 1rem;
  border: 4px solid var(--accent);
  box-shadow: 0 4px 12px rgba(64, 124, 135, 0.2);
}

.user-initials-avatar.small {
  width: 40px;
  height: 40px;
  font-size: 1rem;
  border-width: 2px;
  margin: 0;
}


.rank-badge {
  display: inline-block;
  padding: 0.3rem 0.8rem;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  margin-bottom: 0.5rem;
}

.rank-badge.pro {
  background: linear-gradient(135deg, #A5DBDD 0%, #7ECDD0 100%);
  color: var(--primary);
}

.rank-badge.coach {
  background: linear-gradient(135deg, #407C87 0%, #2D5A63 100%);
  color: var(--white);
}

.rank-points {
  display: block;
  font-size: 0.9rem;
  color: var(--primary);
  font-weight: 600;
  margin: 0.5rem 0;
}

.rank-bar {
  width: 100%;
  height: 6px;
  background: var(--border);
  border-radius: 3px;
  margin-top: 0.75rem;
  overflow: hidden;
}

.rank-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent) 0%, var(--primary) 100%);
  border-radius: 3px;
}

/* ========== LEADERBOARD LIST ========== */
.leaderboard-list {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.leaderboard-item {
  display: flex;
  align-items: center;
  gap: 1rem;
  padding: 1rem;
  background: var(--surface);
  border-radius: 8px;
  transition: var(--ease);
}

.leaderboard-item:hover {
  background: #DFF2F3;
}

.leaderboard-item.is-you {
  border: 1px solid var(--primary);
  background: linear-gradient(135deg, #eaf8f8 0%, #f5fbfc 100%);
}

.leaderboard-item .position {
  font-weight: 700;
  color: var(--primary);
  min-width: 30px;
  text-align: center;
}

.leaderboard-item img {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  object-fit: cover;
  border: 2px solid var(--accent);
}

.item-info {
  flex: 1;
}

.item-info h4 {
  font-size: 0.95rem;
  color: var(--dark);
  margin-bottom: 0.25rem;
}

.badge-small,
.coach-small {
  display: inline-block;
  padding: 0.2rem 0.6rem;
  border-radius: 12px;
  font-size: 0.7rem;
  font-weight: 600;
  background: var(--accent);
  color: var(--primary);
}

.coach-small {
  background: var(--primary);
  color: var(--white);
}

.leaderboard-item .points {
  font-weight: 600;
  color: var(--primary);
  min-width: 80px;
  text-align: right;
}

/* ========== ACHIEVEMENTS ========== */
.achievements-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 1.5rem;
}

.achievement-card {
  background: linear-gradient(135deg, var(--surface) 0%, #f5fbfc 100%);
  border: 2px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  transition: var(--ease);
  cursor: pointer;
}

.achievement-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 8px 24px rgba(64, 124, 135, 0.15);
  border-color: var(--accent);
}

.achievement-icon {
  font-size: 2.5rem;
  margin-bottom: 1rem;
  display: block;
}

.achievement-card h3 {
  font-size: 1rem;
  color: var(--dark);
  margin-bottom: 0.5rem;
}

.achievement-card p {
  font-size: 0.85rem;
  color: #666;
  margin-bottom: 0.75rem;
}

.time {
  display: block;
  font-size: 0.75rem;
  color: var(--primary);
  font-weight: 500;
}

/* ========== STATS SECTION ========== */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 2rem;
}

.stat-box {
  background: linear-gradient(135deg, var(--primary) 0%, #2D5A63 100%);
  border-radius: 12px;
  padding: 3rem 2rem;
  text-align: center;
  color: var(--white);
  position: relative;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(64, 124, 135, 0.2);
  min-height: 200px;
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.stat-box::before {
  content: '';
  position: absolute;
  top: -50%;
  right: -50%;
  width: 200px;
  height: 200px;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.1), transparent);
  border-radius: 50%;
  pointer-events: none;
}

.stat-number {
  font-size: 2.8rem;
  font-weight: 800;
  margin-bottom: 1rem;
  position: relative;
  z-index: 1;
}

.stat-label {
  font-size: 1rem;
  opacity: 0.95;
  position: relative;
  z-index: 1;
  font-weight: 500;
}

.stat-icon {
  font-size: 3rem;
  position: absolute;
  bottom: 15px;
  right: 15px;
  opacity: 0.15;
}

/* ========== RIGHT SIDEBAR WIDGETS ========== */
.sidebar-right {
  position: sticky;
  top: 100px;
  height: fit-content;
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.widget {
  background: var(--white);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1.5rem;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
}

.widget-header {
  margin-bottom: 1.5rem;
  border-bottom: 2px solid var(--surface);
  padding-bottom: 1rem;
}

.widget-header h3 {
  font-size: 1.1rem;
  color: var(--dark);
  margin: 0;
}

/* ========== CHALLENGES WIDGET ========== */
.challenges-list {
  display: flex;
  flex-direction: column;
  gap: 1.2rem;
}
.community-msg {
  padding: 1rem 1.25rem;
  color: var(--dark);
  opacity: 0.85;
  font-size: 0.95rem;
  line-height: 1.5;
}


.challenge-item {
  background: var(--surface);
  border-left: 3px solid var(--accent);
  padding: 1rem;
  border-radius: 6px;
  transition: var(--ease);
}

.challenge-item:hover {
  border-left-color: var(--primary);
  background: #DFF2F3;
}

.challenge-item h4 {
  font-size: 0.95rem;
  color: var(--dark);
  margin-bottom: 0.5rem;
}

.challenge-description {
  font-size: 0.82rem;
  color: #607276;
  margin-bottom: 0.7rem;
}

.challenge-meta {
  display: flex;
  justify-content: space-between;
  font-size: 0.75rem;
  color: #999;
  margin-bottom: 0.75rem;
}

.challenge-progress {
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

.progress-bar {
  flex: 1;
  height: 6px;
  background: var(--border);
  border-radius: 3px;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, var(--accent) 0%, var(--primary) 100%);
}

.progress-text {
  font-size: 0.7rem;
  color: #999;
  min-width: 45px;
  text-align: right;
}

.challenge-actions {
  display: flex;
  gap: 0.5rem;
  margin-top: 0.8rem;
}

.challenge-btn {
  flex: 1;
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 0.45rem 0.6rem;
  font-size: 0.78rem;
  font-weight: 600;
  cursor: pointer;
  transition: var(--ease);
}

.join-btn {
  background: var(--white);
  color: var(--primary);
}

.join-btn:hover:not(:disabled) {
  border-color: var(--primary);
  background: #f0f8fb;
}

.complete-btn {
  background: var(--primary);
  color: var(--white);
  border-color: var(--primary);
}

.complete-btn:hover:not(:disabled) {
  background: #2d5a63;
}

.challenge-btn:disabled {
  opacity: 0.6;
  cursor: not-allowed;
}

.community-msg {
  padding: 1rem 1.25rem;
  color: var(--dark);
  opacity: 0.85;
  font-size: 0.95rem;
  line-height: 1.5;
}

.challenge-item.completed {
  border-left-color: var(--primary);
  background: linear-gradient(135deg, #e5f6f6 0%, #f2fbfb 100%);
}

/* ========== QUICK STATS ========== */
.quick-stats {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 1rem;
}

.quick-stat {
  background: var(--surface);
  padding: 1rem;
  border-radius: 8px;
  text-align: center;
}

.quick-stat .stat-label {
  display: block;
  font-size: 0.75rem;
  color: #999;
  margin-bottom: 0.5rem;
  text-transform: uppercase;
}

.quick-stat .stat-value {
  display: block;
  font-size: 1.1rem;
  font-weight: 700;
  color: var(--primary);
}

/* ========== RESPONSIVE DESIGN ========== */
@media (max-width: 1200px) {
  .main-container {
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  .sidebar-left,
  .sidebar-right {
    position: static;
  }

  .leaderboard-top-3 {
    grid-template-columns: repeat(3, 1fr);
  }

  .achievements-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  .navbar {
    padding: 0 1rem;
  }

  .links {
    gap: 1rem;
    font-size: 0.85rem;
  }

  .main-container {
    padding: 0 1rem;
  }

  .leaderboard-top-3 {
    grid-template-columns: 1fr;
  }

  .rank-card.rank-1 {
    transform: scale(1);
  }

  .achievements-grid {
    grid-template-columns: 1fr;
  }

  .stats-grid {
    grid-template-columns: repeat(2, 1fr);
  }

  .section-header {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 480px) {
  .navbar {
    flex-direction: column;
    gap: 1rem;
  }

  .links {
    flex-wrap: wrap;
    justify-content: center;
  }

  .filter-buttons {
    flex-wrap: wrap;
  }

  .quick-stats {
    grid-template-columns: 1fr;
  }

  .stats-grid {
    grid-template-columns: 1fr;
  }
}
