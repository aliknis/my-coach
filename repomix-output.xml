<file path="pages/products/cart.html">
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Cart - My Coach</title>
    <link rel="icon" type="image/png" href="../../favicon.png" />
    <link rel="stylesheet" href="../../assets/css/products.css" />
  </head>
  <body>
    <div class="container">
      <header>
        <div class="header-content">
          <div class="header-left">
            <nav>
              <a href="../products" class="nav-link">Products</a>
              <a href="" class="nav-link active">Cart</a>
              <a href="payment.html" class="nav-link">Payment</a>
            </nav>
          </div>
        </div>
      </header>

      <main>
        <section class="hero-section">
          <div class="hero-content">
            <div class="hero-icon">🧾</div>
            <h2>Your Cart</h2>
            <p>Review your selected products and total amount.</p>
          </div>
        </section>

        <section class="tab-content active">
          <h3>Cart Items</h3>
          <div class="product-card" id="emptyCartMessage">
            <h4>Your cart is empty.</h4>
            <p class="product-description">
              Go back to products and add items to continue.
            </p>
          </div>
          <div class="products-grid" id="cartItemsContainer"></div>

          <div
            class="product-card"
            id="cartSummary"
            style="margin-top: 24px; padding: 20px"
          >
            <h4>Total</h4>
            <p class="product-description">
              <strong id="cartTotal">$0.00</strong>
            </p>
            <p
              class="product-description"
              id="paymentLinkMessage"
              style="display: none"
            >
              Add at least one item to continue to payment.
            </p>
            <div class="price-section" style="padding: 0">
              <a
                class="btn-add-cart"
                href="../products/"
                style="text-align: center; text-decoration: none"
                >Continue Shopping</a
              >
              <a
                class="btn-add-cart"
                href="payment.html"
                style="text-align: center; text-decoration: none"
                >Proceed to Payment</a
              >
            </div>
          </div>
        </section>
      </main>

      <footer>
        <p>&copy; 2026 My Coach. All rights reserved.</p>
      </footer>
    </div>

    <script>
      const CART_STORAGE_KEY = "myCoachCart";

      function getCartItems() {
        try {
          const storedItems = localStorage.getItem(CART_STORAGE_KEY);
          const parsedItems = storedItems ? JSON.parse(storedItems) : [];
          return Array.isArray(parsedItems) ? parsedItems : [];
        } catch (error) {
          console.warn("Unable to read cart items:", error);
          return [];
        }
      }

      function formatPrice(value) {
        return `$${Number(value).toFixed(2)}`;
      }

      function renderCart() {
        const items = getCartItems();
        const container = document.getElementById("cartItemsContainer");
        const totalElement = document.getElementById("cartTotal");
        const emptyMessage = document.getElementById("emptyCartMessage");
        const paymentLink = document.querySelector('a[href="payment.html"]');
        const paymentLinkMessage =
          document.getElementById("paymentLinkMessage");

        container.innerHTML = "";

        if (items.length === 0) {
          emptyMessage.style.display = "block";
          if (paymentLink) {
            paymentLink.style.pointerEvents = "none";
            paymentLink.style.opacity = "0.6";
            paymentLink.setAttribute("aria-disabled", "true");
          }
          if (paymentLinkMessage) {
            paymentLinkMessage.style.display = "block";
          }
          totalElement.textContent = formatPrice(0);
          return;
        }

        emptyMessage.style.display = "none";
        if (paymentLink) {
          paymentLink.style.pointerEvents = "auto";
          paymentLink.style.opacity = "1";
          paymentLink.removeAttribute("aria-disabled");
        }
        if (paymentLinkMessage) {
          paymentLinkMessage.style.display = "none";
        }

        let total = 0;
        items.forEach((item) => {
          const card = document.createElement("div");
          card.className = "product-card";
          card.innerHTML = `
                    <h4>${item.name || "Item"}</h4>
                    <p class="product-description">Quantity: 1</p>
                    <div class="price-section" style="padding-top: 0;">
                        <span class="price">${formatPrice(item.price || 0)}</span>
                    </div>
                `;
          container.appendChild(card);
          total += Number(item.price) || 0;
        });

        totalElement.textContent = formatPrice(total);
      }

      document.addEventListener("DOMContentLoaded", renderCart);
    </script>
  </body>
</html>
</file>

<file path="pages/products/payment.html">
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Payment - My Coach</title>
    <link rel="icon" type="image/png" href="../../favicon.png" />
    <link rel="stylesheet" href="../../assets/css/products.css" />
  </head>
  <body>
    <div class="container">
      <header>
        <div class="header-content">
          <div class="header-left">
            <nav>
              <a href="../products" class="nav-link">Products</a>
              <a href="cart.html" class="nav-link">Cart</a>
              <a href="" class="nav-link active">Payment</a>
            </nav>
          </div>
        </div>
      </header>

      <main>
        <section class="hero-section">
          <div class="hero-content">
            <div class="hero-icon">💳</div>
            <h2>Payment</h2>
            <p>Select your payment method and complete your order.</p>
          </div>
        </section>

        <section class="tab-content active">
          <h3>Choose Payment Method</h3>
          <div class="product-card" style="padding: 20px">
            <form id="paymentForm">
              <div class="product-specs" style="margin-bottom: 20px">
                <label class="spec"
                  ><input
                    type="radio"
                    name="paymentMethod"
                    value="card"
                    checked
                  />
                  Credit / Debit Card</label
                >
                <label class="spec"
                  ><input type="radio" name="paymentMethod" value="paypal" />
                  PayPal</label
                >
                <label class="spec"
                  ><input type="radio" name="paymentMethod" value="cash" /> Cash
                  on Delivery</label
                >
              </div>

              <div class="product-specs">
                <label class="spec"
                  >Cardholder Name<br /><input
                    type="text"
                    id="cardName"
                    required
                    style="width: 100%; margin-top: 8px; padding: 10px"
                /></label>
                <label class="spec"
                  >Card Number<br /><input
                    type="tel"
                    id="cardNumber"
                    inputmode="numeric"
                    maxlength="19"
                    required
                    style="width: 100%; margin-top: 8px; padding: 10px"
                /></label>
                <label class="spec"
                  >Expiry Date<br /><input
                    type="month"
                    id="expiryDate"
                    min=""
                    required
                    style="width: 100%; margin-top: 8px; padding: 10px"
                /></label>
                <label class="spec"
                  >CVV<br /><input
                    type="password"
                    id="cvv"
                    inputmode="numeric"
                    maxlength="4"
                    required
                    style="width: 100%; margin-top: 8px; padding: 10px"
                /></label>
              </div>

              <div class="price-section" style="padding: 20px 0 0 0">
                <a
                  class="btn-add-cart"
                  href="cart.html"
                  style="text-align: center; text-decoration: none"
                  >Back to Cart</a
                >
                <button class="btn-add-cart" type="submit">Pay Now</button>
              </div>
            </form>
          </div>
        </section>
      </main>

      <footer>
        <p>&copy; 2026 My Coach. All rights reserved.</p>
      </footer>
    </div>

    <script>
      const CART_STORAGE_KEY = "myCoachCart";

      function toggleCardFields() {
        const selectedMethod = document.querySelector(
          'input[name="paymentMethod"]:checked',
        )?.value;
        const cardInputs = ["cardName", "cardNumber", "expiryDate", "cvv"]
          .map((id) => document.getElementById(id))
          .filter(Boolean);
        const isCardMethod = selectedMethod === "card";

        cardInputs.forEach((input) => {
          input.required = isCardMethod;
          input.disabled = !isCardMethod;
          input.closest("label").style.opacity = isCardMethod ? "1" : "0.6";
        });
      }

      document.addEventListener("DOMContentLoaded", () => {
        const expiryDateInput = document.getElementById("expiryDate");
        if (expiryDateInput) {
          const now = new Date();
          const month = String(now.getMonth() + 1).padStart(2, "0");
          expiryDateInput.min = `${now.getFullYear()}-${month}`;
        }

        document
          .querySelectorAll('input[name="paymentMethod"]')
          .forEach((radio) => {
            radio.addEventListener("change", toggleCardFields);
          });
        toggleCardFields();

        const paymentForm = document.getElementById("paymentForm");
        if (!paymentForm) {
          console.warn("Payment form not found.");
          return;
        }

        paymentForm.addEventListener("submit", (event) => {
          event.preventDefault();
          alert("Payment submitted successfully!");
          localStorage.removeItem(CART_STORAGE_KEY);
          window.location.href = "products.html";
        });
      });
    </script>
  </body>
</html>
</file>

